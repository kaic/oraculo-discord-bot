# Copie para .dev.vars e preencha para desenvolvimento local.
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
GEMINI_API_KEY=

# Opcional: habilita consulta exata da última partida de LoL por Riot ID Nome#TAG.
RIOT_API_KEY=

# Usado apenas pelo script npm run register:command.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_GUILD_IDS=

# Overrides opcionais.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=900
GEMINI_THINKING_BUDGET=0
ENABLE_GOOGLE_SEARCH=true
ALLOWED_GUILD_IDS=
RIOT_ROUTING_REGION=americas
RIOT_HISTORY_MATCH_COUNT=40
ORACLE_RESPONSE_MAX_CHARS=750
ORACULO_CONSTITUTION=
ENVIRONMENT=development
